// EdgeBoard — Prisma schema.
// Phase 1 only: Auth.js (NextAuth) standard models + Subscription.
// Later phases add markets, price_snapshots, trades, whale_wallets, etc. (see docs/instruction.md §6).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- Auth.js standard models ----------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------- Business model (Phase 1) ----------

enum Plan {
  free
  pro
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  plan                 Plan      @default(free)
  status               String    @default("active")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ---------- Market ingestion (Phase 2) ----------
// Cache of Polymarket markets (from Gamma /markets) + a YES-price time series.
// Money/price fields are Decimal (Postgres numeric), never float — see §6.

model Market {
  id             String    @id @default(cuid())
  conditionId    String    @unique @map("condition_id")
  slug           String?
  question       String
  category       String?
  clobTokenIdYes String?   @map("clob_token_id_yes")
  clobTokenIdNo  String?   @map("clob_token_id_no")
  volume         Decimal?  @default(0) @db.Decimal(20, 6)
  liquidity      Decimal?  @default(0) @db.Decimal(20, 6)
  closed         Boolean   @default(false)
  endDate        DateTime? @map("end_date")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  priceSnapshots PriceSnapshot[]

  @@map("markets")
}

model PriceSnapshot {
  id       String   @id @default(cuid())
  marketId String   @map("market_id")
  tokenId  String   @map("token_id")
  price    Decimal  @db.Decimal(12, 6)
  ts       DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, ts])
  @@map("price_snapshots")
}
