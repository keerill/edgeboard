// EdgeBoard — Prisma schema.
// Phase 1 only: Auth.js (NextAuth) standard models + Subscription.
// Later phases add markets, price_snapshots, trades, whale_wallets, etc. (see docs/instruction.md §6).

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------- Auth.js standard models ----------

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  telegramChatId String?   @map("telegram_chat_id") // optional Telegram delivery target (Phase 7)
  createdAt      DateTime  @default(now()) @map("created_at")

  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  trackedWallets TrackedWallet[]
  alerts         Alert[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ---------- Business model (Phase 1) ----------

enum Plan {
  free
  pro
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique @map("user_id")
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  plan                 Plan      @default(free)
  status               String    @default("active")
  currentPeriodEnd     DateTime? @map("current_period_end")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// ---------- Market ingestion (Phase 2) ----------
// Cache of Polymarket markets (from Gamma /markets) + a YES-price time series.
// Money/price fields are Decimal (Postgres numeric), never float — see §6.

model Market {
  id             String    @id @default(cuid())
  conditionId    String    @unique @map("condition_id")
  slug           String?
  question       String
  category       String?
  clobTokenIdYes String?   @map("clob_token_id_yes")
  clobTokenIdNo  String?   @map("clob_token_id_no")
  volume         Decimal?  @default(0) @db.Decimal(20, 6)
  liquidity      Decimal?  @default(0) @db.Decimal(20, 6)
  closed         Boolean   @default(false)
  endDate        DateTime? @map("end_date")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  priceSnapshots PriceSnapshot[]
  trades         Trade[]
  alerts         Alert[]

  @@map("markets")
}

model PriceSnapshot {
  id       String   @id @default(cuid())
  marketId String   @map("market_id")
  tokenId  String   @map("token_id")
  price    Decimal  @db.Decimal(12, 6)
  ts       DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, ts])
  @@map("price_snapshots")
}

// ---------- Trades & whales (Phase 3) ----------
// Large ("whale") trades ingested from the Data API + per-wallet aggregates.
// Money/price fields are Decimal (Postgres numeric), never float — see §6.

model Trade {
  id        String   @id @default(cuid())
  marketId  String   @map("market_id")
  wallet    String // proxyWallet, lowercased
  side      String // "buy" | "sell"
  sizeUsdc  Decimal  @map("size_usdc") @db.Decimal(20, 6)
  price     Decimal  @db.Decimal(12, 6)
  isWhale   Boolean  @map("is_whale")
  ts        DateTime
  asset     String?  @map("asset_token_id") // outcome token id (FIFO P&L grouping)
  outcome   String? // outcome label, e.g. "Yes" / "No" (display)
  txHash    String?  @map("tx_hash") // on-chain tx, for block-explorer linking
  dedupeKey String   @unique @map("dedupe_key") // idempotent upsert key (§7)

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([ts])
  @@index([wallet])
  @@index([marketId, ts])
  @@map("trades")
}

model WhaleWallet {
  address         String    @id
  totalVolumeUsdc Decimal   @default(0) @map("total_volume_usdc") @db.Decimal(20, 6)
  realizedPnl     Decimal?  @map("realized_pnl") @db.Decimal(20, 6)
  winRate         Decimal?  @map("win_rate") @db.Decimal(5, 4)
  lastActive      DateTime? @map("last_active")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("whale_wallets")
}

// ---------- Portfolio (Phase 4) ----------
// Public wallet addresses a user saves to view their Polymarket portfolio.
// Read-only: an address is just a public string — no wallet connect/signing (§2).

model TrackedWallet {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  address   String // public address, stored lowercased
  label     String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address]) // no duplicate wallet per user
  @@index([userId])
  @@map("tracked_wallets")
}

// ---------- Alerts (Phase 7 / v1.1) ----------
// User-defined notifications delivered by email/Telegram (spec §6, §8). A Pro-only
// feature (§10). The spec lists a single polymorphic `target`; we split it into typed
// columns (marketId FK + wallet + threshold) for integrity and strict-friendly queries.
// `lastFiredAt` is a per-alert watermark for de-dup/cooldown (see jobs/check-alerts.ts).

enum AlertType {
  whale_move // a new whale trade matches the scope (market/wallet/min-USDC)
  price_swing // scoped market's YES price moves >= threshold percentage-points
  market // scoped market closes/resolves
}

enum AlertChannel {
  email
  telegram
}

model Alert {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  type        AlertType
  channel     AlertChannel @default(email)
  marketId    String?      @map("market_id") // required for price_swing/market; optional for whale_move
  wallet      String? // optional whale_move scope, stored lowercased
  threshold   Decimal?     @db.Decimal(20, 6) // whale_move: min USDC; price_swing: percentage-points
  active      Boolean      @default(true)
  lastFiredAt DateTime?    @map("last_fired_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market? @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([active])
  @@map("alerts")
}
