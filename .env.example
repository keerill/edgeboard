# Copy to .env.local and fill in real values. Never commit secrets.
# Phase 1 needs: DATABASE_URL, NEXTAUTH_SECRET (to boot) + Google/Resend creds (to sign in).

# --- Database (Phase 1) ---
# Local Docker default: postgresql://edgeboard:edgeboard@localhost:5432/edgeboard?schema=public
DATABASE_URL=

# --- Auth.js / NextAuth (Phase 1) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=                          # SMTP for magic link (alternative to Resend; unused by default)
RESEND_API_KEY=                        # magic-link email transport (default)
EMAIL_FROM=                            # verified Resend sender, e.g. auth@yourdomain.com

# --- Stripe (Phase 5) ---
# Success/return URLs are derived from the request host (falls back to NEXTAUTH_URL) — no extra var.
STRIPE_SECRET_KEY=                      # sk_test_… (Stripe test mode)
STRIPE_WEBHOOK_SECRET=                  # whsec_… from `stripe listen` (local) or the endpoint's signing secret (Vercel)
STRIPE_PRICE_ID_PRO=                    # price_… of the recurring €15/mo Pro price
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # unused in MVP (checkout uses a server-side hosted redirect)

# --- Polymarket APIs (Phase 2+) ---
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com

# --- Background jobs / ingestion (Phase 2+) ---
CRON_SECRET=                           # required by /api/cron/* (Phase 2); Vercel Cron sends it as a Bearer token
WHALE_THRESHOLD_USDC=5000              # Phase 3

# --- Observability & analytics (Phase 6) ---
# All optional: each integration is a clean no-op until its var is set.
SENTRY_DSN=                            # server/edge error capture; unset => Sentry disabled
NEXT_PUBLIC_SENTRY_DSN=                # client error capture (a DSN is public-safe); unset => disabled
SENTRY_ORG=                            # source-map upload only (CI/prod); unset => upload skipped
SENTRY_PROJECT=                        # source-map upload only
SENTRY_AUTH_TOKEN=                     # source-map upload only — SECRET, set in Vercel/CI env, leave empty here
NEXT_PUBLIC_POSTHOG_KEY=               # phc_… project key; unset => analytics disabled
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com   # PostHog region (use https://eu.i.posthog.com for EU)

# --- Alerts (Phase 7 / v1.1) ---
# No new variable: email alerts reuse RESEND_API_KEY + EMAIL_FROM (above); alert
# links use NEXTAUTH_URL; the cron reuses CRON_SECRET. Each channel soft-degrades
# (skipped, not errored) until configured.
TELEGRAM_BOT_TOKEN=                    # Telegram Bot API token for Telegram alerts; unset => Telegram channel skipped
