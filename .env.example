# Copy to .env.local and fill in real values. Never commit secrets.
# Phase 1 needs: DATABASE_URL, NEXTAUTH_SECRET (to boot) + Google/Resend creds (to sign in).

# --- Database (Phase 1) ---
# Local Docker default: postgresql://edgeboard:edgeboard@localhost:5432/edgeboard?schema=public
DATABASE_URL=

# --- Auth.js / NextAuth (Phase 1) ---
NEXTAUTH_SECRET=
NEXTAUTH_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=                          # SMTP for magic link (alternative to Resend; unused by default)
RESEND_API_KEY=                        # magic-link email transport (default)
EMAIL_FROM=                            # verified Resend sender, e.g. auth@yourdomain.com

# --- Stripe (Phase 5) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Polymarket APIs (Phase 2+) ---
GAMMA_API_BASE=https://gamma-api.polymarket.com
CLOB_API_BASE=https://clob.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com

# --- Background jobs / ingestion (Phase 2+) ---
CRON_SECRET=
WHALE_THRESHOLD_USDC=5000

# --- Observability & analytics (Phase 6) ---
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# --- Alerts (Phase 7 / v1.1) ---
TELEGRAM_BOT_TOKEN=
